server
{
    listen 80;
    listen 443 ssl http2 ;
    server_name go.fatep.eu.org;
    index index.html index.htm;
    root /www/wwwroot/go.fatep.eu.org;

    # SSL Certificate Config
    ssl_certificate    /www/server/panel/vhost/cert/go.fatep.eu.org/fullchain.pem;
    ssl_certificate_key    /www/server/panel/vhost/cert/go.fatep.eu.org/privkey.pem;
    ssl_protocols TLSv1.1 TLSv1.2 TLSv1.3;
    ssl_ciphers EECDH+CHACHA20:EECDH+CHACHA20-draft:EECDH+AES128:RSA+AES128:EECDH+AES256:RSA+AES256:EECDH+3DES:RSA+3DES:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_tickets on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    add_header Strict-Transport-Security "max-age=31536000";
    error_page 497  https://$host$request_uri;

    # Prevent access to sensitive files
    location ~ ^/(\.user.ini|\.htaccess|\.git|\.env|\.svn|\.project|LICENSE|README.md)
    {
        return 404;
    }

    # SSL certificate challenge folder
    location ~ \.well-known{
        allow all;
    }

    # Serve custom premium landing page
    location = / {
      root /www/wwwroot/go.fatep.eu.org;
      try_files /index.html =404;
    }

    # Serve custom dashboard page
    location = /dashboard {
      root /www/wwwroot/go.fatep.eu.org;
      try_files /dashboard.html =404;
    }

    # Serve global styles
    location = /style.css {
      root /www/wwwroot/go.fatep.eu.org;
      try_files /style.css =404;
    }

    # Relay REST API requests to backend shortlink container
    location /api/ {
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header Host $http_host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_redirect off;
      proxy_pass http://127.0.0.1:25504;
      proxy_buffering off;
    }

    # Fallback all other shortlink slug redirects to container
    location / {
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header Host $http_host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_redirect off;
      proxy_pass http://127.0.0.1:25504;
      proxy_buffering off;
    }
    
    access_log  /www/wwwlogs/go.fatep.eu.org.log;
    error_log  /www/wwwlogs/go.fatep.eu.org.error.log;
}
